# =============================================================================
# EASM Pipeline Configuration
# =============================================================================

# --- Identity ---
USER_AGENT="EASM-Pipeline/0.1"

# --- Input ---
INPUT_SUBDOMAINS="data/input/subdomains.txt"
CMDB_EXPORT="data/input/cmdb_export.csv"

# --- Output directories ---
OUTPUT_DIR="data/output"
SCREENSHOT_DIR="data/screenshots"
CACHE_DIR="data/cache"
LOG_DIR="logs"

# --- Root domains for CT log enrichment ---
ROOT_DOMAINS="example.com,example.org"

# --- DNS (dnsx) ---
DNS_RATE_LIMIT=500
DNS_RETRIES=2
DNS_RECORD_TYPES="a,aaaa,cname,ns,mx,txt"

# --- Port Scanning (naabu) ---
NAABU_TOP_PORTS=100
NAABU_RATE=1000
NAABU_WORKERS=25
NAABU_RETRIES=1
NAABU_EXCLUDE_CDN=true

# --- HTTP Probing (httpx) ---
HTTPX_THREADS=50
HTTPX_RATE_LIMIT=150
HTTPX_TIMEOUT=10
HTTPX_RETRIES=2
HTTPX_MAX_HOST_ERROR=30
HTTPX_SCREENSHOTS=true

# --- TLS (tlsx) ---
TLSX_CONCURRENCY=25
TLSX_SCAN_MODE="auto"

# --- zgrab2 ---
ZGRAB_SENDERS=100
ZGRAB_TIMEOUT=10

# --- Nuclei ---
NUCLEI_RATE_LIMIT=50
NUCLEI_BULK_SIZE=25
NUCLEI_CONCURRENCY=25
NUCLEI_TIMEOUT=10
NUCLEI_RETRIES=1
NUCLEI_TAGS="technologies,takeovers,exposures,misconfiguration,default-logins,exposed-panels"
NUCLEI_EXCLUDE_TAGS="intrusive,dos,fuzz"
NUCLEI_SEVERITIES="info,low,medium,high,critical"

# --- DuckDB ---
DUCKDB_PATH="data/output/easm.duckdb"

# --- Cache TTL (seconds) ---
CACHE_TTL=86400

# --- Web ports for HTTP probing ---
WEB_PORTS="80,81,443,591,2082,2083,2086,2087,2095,2096,3000,3128,4443,5000,5001,5601,7001,7002,8000,8008,8080,8081,8090,8443,8888,9000,9001,9090,9200,9443"

# --- TLS ports for deep TLS grab ---
TLS_PORTS="443,465,563,636,853,989,990,992,993,994,995,4443,5061,5986,6443,8443,9443"

# --- Nerva (replaces zgrab2 as primary fingerprinting engine) ---
# NERVA_TIMEOUT is in seconds; run_nerva.sh converts to ms for nerva -w flag.
NERVA_TIMEOUT=10
NERVA_THREADS=50
NERVA_FAST_MODE=false
NERVA_UDP=false
NERVA_VERBOSE=false
NERVA_MISCONFIGS=false   # enable --misconfigs to surface unauth APIs, weak SSH, etc.

# --- Fingerprinting backend ---
# Set to "zgrab2" to fall back to zgrab2; set ZGRAB2_FALLBACK=true to run both.
FINGERPRINT_BACKEND=nerva
ZGRAB2_FALLBACK=false

# --- Legacy zgrab2 (deprecated — kept for optional fallback only) ---
# ZGRAB_SENDERS=100
# To use zgrab2 as fallback: FINGERPRINT_BACKEND=zgrab2
# To use zgrab2 alongside nerva for deep handshakes: ZGRAB2_FALLBACK=true
