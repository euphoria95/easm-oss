# =============================================================================
# EASM Pipeline Configuration
# =============================================================================

# --- Pipeline Mode ---
# "recon" (default) or "bounty" — bounty mode expands scanning depth
PIPELINE_MODE=recon

# --- Identity ---
USER_AGENT="EASM-Pipeline/0.1"

# --- Input ---
INPUT_SUBDOMAINS="data/input/subdomains.txt"
CMDB_EXPORT="data/input/cmdb_export.csv"

# --- Output directories ---
OUTPUT_DIR="data/output"
SCREENSHOT_DIR="data/screenshots"
CACHE_DIR="data/cache"
LOG_DIR="logs"

# --- DNS (dnsx) ---
DNS_RATE_LIMIT=50
DNS_RETRIES=2
DNS_RECORD_TYPES="a,aaaa,cname,ns,mx,txt"

# --- Port Scanning (naabu) ---
NAABU_TOP_PORTS=100
NAABU_PORTS=
NAABU_RATE=200
NAABU_WORKERS=25
NAABU_RETRIES=1
NAABU_EXCLUDE_CDN=true

# --- HTTP Probing (httpx) ---
HTTPX_THREADS=20
HTTPX_RATE_LIMIT=20
HTTPX_TIMEOUT=10
HTTPX_RETRIES=2
HTTPX_MAX_HOST_ERROR=30
HTTPX_SCREENSHOTS=true

# --- TLS (tlsx) ---
TLSX_CONCURRENCY=25
TLSX_SCAN_MODE="auto"

# --- zgrab2 ---
ZGRAB_SENDERS=100
ZGRAB_TIMEOUT=10

# --- Nuclei ---
NUCLEI_RATE_LIMIT=20
NUCLEI_BULK_SIZE=25
NUCLEI_CONCURRENCY=20
NUCLEI_TIMEOUT=10
NUCLEI_RETRIES=1
NUCLEI_TAGS="technologies,takeovers,exposures,misconfiguration,default-logins,exposed-panels"
NUCLEI_EXCLUDE_TAGS="intrusive,dos,fuzz"
NUCLEI_SEVERITIES="info,low,medium,high,critical"

# --- DuckDB ---
DUCKDB_PATH="data/output/easm.duckdb"

# --- Cache TTL (seconds) ---
CACHE_TTL=86400

# --- Web ports for HTTP probing ---
WEB_PORTS="80,443,8080,8443,8444,9443"

# --- TLS ports for deep TLS grab ---
TLS_PORTS="443,8443,8444,9443"

# --- Nerva (replaces zgrab2 as primary fingerprinting engine) ---
# NERVA_TIMEOUT is in seconds; run_nerva.sh converts to ms for nerva -w flag.
NERVA_TIMEOUT=3
NERVA_THREADS=50
NERVA_FAST_MODE=true
NERVA_UDP=false
NERVA_VERBOSE=false
NERVA_MISCONFIGS=true    # enable --misconfigs to surface unauth APIs, weak SSH, etc.

# --- Fingerprinting backend ---
# Set to "zgrab2" to fall back to zgrab2; set ZGRAB2_FALLBACK=true to run both.
FINGERPRINT_BACKEND=nerva
ZGRAB2_FALLBACK=false

# --- Legacy zgrab2 (deprecated — kept for optional fallback only) ---
# ZGRAB_SENDERS=100
# To use zgrab2 as fallback: FINGERPRINT_BACKEND=zgrab2
# To use zgrab2 alongside nerva for deep handshakes: ZGRAB2_FALLBACK=true

# --- Debug / Performance monitoring ---
DEBUG_MODE=false

# --- Service Detection Fallback ---
# When httpx fails to probe a port, run naabu -sV for service identification.
SERVICE_DETECT_FALLBACK=true
SERVICE_DETECT_RATE=100
